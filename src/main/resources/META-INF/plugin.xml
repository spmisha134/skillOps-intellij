<idea-plugin>
    <id>com.spmisha134.buildskill</id>
    <name>BuildSkill Intellij</name>
    <vendor>spmisha134</vendor>
    <description><![CDATA[
        <p>Create and validate Codex/OpenAI skills directly inside IntelliJ IDEA.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <actions>
        <action id="com.spmisha134.buildskill.NewBuildSkill"
                class="com.spmisha134.buildskill.actions.CreateSkillAction"
                text="BuildSkill"
                description="Create a new Codex skill under .agents/skills.">
            <add-to-group group-id="NewGroup" anchor="last"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="com.spmisha134.buildskill.ValidateBuildSkill"
                class="com.spmisha134.buildskill.actions.ValidateSkillAction"
                text="Validate BuildSkill"
                description="Validate a Codex skill folder.">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
